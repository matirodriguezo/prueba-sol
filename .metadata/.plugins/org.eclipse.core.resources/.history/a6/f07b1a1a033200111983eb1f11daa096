package com.example.demo.service;

import java.util.Arrays;
import java.util.Collections;
import java.util.List;

import org.springframework.stereotype.Service;
import org.springframework.web.client.RestTemplate;

import com.example.demo.entity.PlatoEntity;
import com.example.demo.interfaces.IPlatoService;

@Service
public class PlatoServiceImpl implements IPlatoService {

    private final String BASE_URL = "http://demo02:8884/api/v1/entities/persona/";
    private final RestTemplate restTemplate = new RestTemplate();

    @Override
    public List<PlatoEntity> findAll() {
        try {
            PlatoEntity[] paltosArray = restTemplate.getForObject(BASE_URL, PlatoEntity[].class);
            if (platosArray != null) {
                return Arrays.asList(platosArray);
            }
            return Collections.emptyList();
        } catch (Exception e) {
            e.printStackTrace();
            return Collections.emptyList();
        }
    }

    @Override
    public PlatoEntity findById(Long id) {
        try {
            return restTemplate.getForObject(BASE_URL + id, PlatoEntity.class);
        } catch (Exception e) {
            e.printStackTrace();
            return null;
        }
    }

    @Override
    public PlatoEntity save(PlatoEntity plato) {
        try {
            if (plato.getId() != null) {

                restTemplate.put(BASE_URL + plato.getId(), plato);
                return plato;
            } else {

                return restTemplate.postForObject(BASE_URL, plato, PlatoEntity.class);
            }
        } catch (Exception e) {
            e.printStackTrace();
            return null;
        }
    }

    @Override
    public void deleteById(Long id) {
        try {
            restTemplate.delete(BASE_URL + id);
        } catch (Exception e) {
            e.printStackTrace();
        }
    }
}